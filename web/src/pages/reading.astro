---
import Base from '../layouts/Base.astro'
import {sanityClient} from 'sanity:client'
import {currentlyReadingQuery, bookCoverUrl} from '../utils/sanity'

const reading = await sanityClient.fetch(currentlyReadingQuery)
---

<Base title="Currently Reading - waglesworld" description="What I'm reading right now.">
  <h1>Currently Reading</h1>
  <p class="intro">What's on my nightstand right now. When I finish a book, it moves to <a href="/books">reviews</a>.</p>

  {
    reading.length === 0 ? (
      <p class="empty">Nothing right now — between books. Check out my <a href="/books">reviews</a> for what I've read recently.</p>
    ) : (
      <ul class="reading-list">
        {reading.map((book: any) => {
          const cover = bookCoverUrl(book)
          const progress = book.currentPage && book.totalPages
            ? Math.round((book.currentPage / book.totalPages) * 100)
            : null

          return (
            <li>
              <div class="book-card">
                {cover && <img src={cover} alt={book.title} class="cover" loading="lazy" />}
                <div class="info">
                  <span class="book-title">{book.title}</span>
                  <span class="book-author">by {book.bookAuthor}</span>
                  {book.startedAt && (
                    <span class="started">
                      Started {new Date(book.startedAt).toLocaleDateString('en-US', {
                        month: 'short',
                        day: 'numeric',
                        year: 'numeric',
                      })}
                    </span>
                  )}
                  {progress !== null && (
                    <div class="progress-wrap">
                      <div class="progress-bar">
                        <div class="progress-fill" style={`width: ${progress}%`} />
                      </div>
                      <span class="progress-text">
                        {book.currentPage} / {book.totalPages} pages ({progress}%)
                      </span>
                    </div>
                  )}
                  {book.tags && book.tags.length > 0 && (
                    <div class="tags">
                      {book.tags.map((tag: string) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </li>
          )
        })}
      </ul>
    )
  }

  <a href="/books" class="see-all">&larr; See all book reviews</a>
</Base>

<style>
  .intro {
    color: #666;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  .intro a {
    color: #0066cc;
    text-decoration: underline;
  }

  .empty {
    color: #666;
    margin-top: 1rem;
  }

  .empty a {
    color: #0066cc;
    text-decoration: underline;
  }

  .reading-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .book-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }

  .cover {
    width: 80px;
    height: auto;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .book-title {
    font-weight: 600;
    font-size: 1.15rem;
  }

  .book-author {
    color: #666;
    font-size: 0.95rem;
  }

  .started {
    color: #999;
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }

  .progress-wrap {
    margin-top: 0.5rem;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: #f0f0f0;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #1a1a1a;
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  .progress-text {
    font-size: 0.75rem;
    color: #999;
    margin-top: 0.25rem;
    display: block;
  }

  .tags {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #f0f0f0;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.75rem;
    color: #555;
  }

  .see-all {
    display: inline-block;
    margin-top: 2rem;
    color: #666;
    font-size: 0.875rem;
  }

  @media (max-width: 480px) {
    .book-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .cover {
      width: 100px;
    }

    .info {
      align-items: center;
    }

    .tags {
      justify-content: center;
    }
  }
</style>
